---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import MusingsSolarSystemBackground from "../../components/MusingsSolarSystemBackground.astro";
import { formatDate } from "../../utils/date";

const posts = (await getCollection("musings"))
  .filter(({ data }) => !data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const buildMusingsUrl = (slug: string, date: Date): string => {
  const year = String(date.getFullYear());
  const month = String(date.getMonth() + 1).padStart(2, "0");
  const day = String(date.getDate()).padStart(2, "0");
  return `/musings/${year}/${month}/${day}/${slug}/`;
};
---

<BaseLayout title="Musings | Cpuritan" description="Musings posts">
  <section class="musings-page">
    <MusingsSolarSystemBackground />
    <h1>Musings</h1>
    {
      posts.length > 0 ? (
        <div class="blog-grid musings-page__grid">
          {posts.map((post) => (
            <article class="blog-card">
              <h2>
                <a href={buildMusingsUrl(post.slug, post.data.date)}>{post.data.title}</a>
              </h2>
              <p class="meta">{formatDate(post.data.date)}</p>
              {post.data.tags && post.data.tags.length > 0 ? (
                <p class="tags">{post.data.tags.join(" / ")}</p>
              ) : null}
            </article>
          ))}
        </div>
      ) : (
        <p class="meta">No musings yet. Check back soon.</p>
      )
    }
  </section>
</BaseLayout>

<style>
  .musings-page {
    position: relative;
    z-index: 1;
    min-height: clamp(28rem, 58vw, 38rem);
    padding-top: clamp(1rem, 2vw, 1.5rem);
    isolation: isolate;
  }

  .musings-page h1,
  .musings-page__grid,
  .musings-page > .meta {
    position: relative;
    z-index: 1;
  }

  .musings-page h1 {
    margin-bottom: 1rem;
  }

  .musings-page__grid {
    gap: 0.9rem;
  }

  .musings-page__grid .blog-card {
    background: transparent;
    border-color: rgba(176, 184, 197, 0.52);
    box-shadow: none;
    backdrop-filter: none;
  }
</style>
