---
import { getEntry, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const entry = await getEntry("site", "research");

if (!entry) {
  throw new Error("Missing site content entry: research");
}

const { Content } = await render(entry);
---

<BaseLayout title="Research | Cpuritan" description="Research directions">
  <section>
    <Content />
  </section>
</BaseLayout>
