---
import BaseLayout from "../layouts/BaseLayout.astro";
import scheduleFallback from "../data/schedule.json";

const today = new Date();
const todayStr = new Intl.DateTimeFormat("en-CA", {
  timeZone: "Asia/Shanghai",
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
}).format(today);

const categories = [
  { key: "research", zh: "科研", h: "215", s: "65" },
  { key: "study",    zh: "学习", h: "270", s: "55" },
  { key: "life",     zh: "生活", h: "145", s: "45" },
  { key: "outing",   zh: "外出", h: "30",  s: "75" },
  { key: "ddl",      zh: "DDL",  h: "0",   s: "70" },
  { key: "other",    zh: "其他", h: "0",   s: "0"  },
] as const;

function baseColor(cat: string): string {
  const c = categories.find((x) => x.key === cat);
  if (!c) return "#6b7280";
  return `hsl(${c.h}, ${c.s}%, 48%)`;
}
---
<BaseLayout
  title="Schedule | Cpuritan"
  description="Qifeng Bao — calendar and schedule"
>
  <div
    class="sched-page"
    data-schedule={JSON.stringify(scheduleFallback)}
    data-today={todayStr}
    data-api="https://cpuritan-schedule.bqf-cpuritan.workers.dev/api"
  >
    <header class="sched-toolbar">
      <div class="sched-title"><h1>Calendar</h1></div>
      <div class="sched-actions">
        <div class="tb-group">
          <button type="button" class="tb-btn" id="prev-month" aria-label="上月">‹</button>
          <span class="tb-label" id="month-label">2026 年 7 月</span>
          <button type="button" class="tb-btn" id="next-month" aria-label="下月">›</button>
        </div>
        <button type="button" class="tb-btn tb-today" id="today-btn">今日</button>
        <button type="button" class="tb-btn tb-login" id="login-btn" title="回答问题以管理">⚙</button>
      </div>
    </header>

    <div class="sched-grid">
      <section class="cal-panel" aria-label="月历">
        <div class="cal-head">
          <span>一</span><span>二</span><span>三</span><span>四</span><span>五</span><span>六</span><span>日</span>
        </div>
        <div class="cal-body" id="cal-body"></div>
      </section>

      <section class="agenda-panel" aria-label="日程列表">
        <div class="agenda-head">
          <button type="button" class="day-btn" id="prev-day" aria-label="前一天">‹</button>
          <h2 id="agenda-title">今日日程</h2>
          <button type="button" class="day-btn" id="next-day" aria-label="后一天">›</button>
          <span class="agenda-count" id="agenda-count"></span>
          <span id="save-indicator" hidden style="margin-left:auto;font-size:.7rem;color:var(--st-muted);font-weight:400;">保存中…</span>
        </div>
        <ul class="agenda-list" id="agenda-list"></ul>
        <div class="agenda-edit-actions" id="agenda-edit-actions" hidden>
          <button type="button" class="ed-btn ed-add" id="add-btn">+ 新增日程</button>
        </div>
      </section>
    </div>
  </div>

  <!-- ===== Login dialog ===== -->
  <dialog class="dlg" id="login-dlg" aria-label="回答问题">
    <form method="dialog" class="dlg-form" id="login-form">
      <h3>回答问题以编辑日程</h3>
      <label class="dlg-field">
        <span id="login-question">章鱼哥的紧箍咒是？</span>
        <input type="text" name="answer" id="login-answer" autocomplete="off" required />
      </label>
      <p class="dlg-error" id="login-error" hidden></p>
      <div class="dlg-actions">
        <button type="button" class="ed-btn ghost" id="login-cancel">取消</button>
        <button type="submit" class="ed-btn primary">提交</button>
      </div>
    </form>
  </dialog>

  <!-- ===== Edit dialog ===== -->
  <dialog class="dlg" id="edit-dlg" aria-label="编辑日程">
    <form method="dialog" class="dlg-form" id="edit-form">
      <h3 id="edit-title">新增日程</h3>

      <div class="mode-tabs" id="mode-tabs">
        <button type="button" class="mode-tab is-active" data-mode="single">日程计划</button>
        <button type="button" class="mode-tab" data-mode="period">周期规划</button>
      </div>

      <input type="hidden" name="id" id="edit-id" />

      <div id="single-fields">
        <label class="dlg-field">
          <span>日期</span>
          <input type="date" name="date" id="edit-date" required />
        </label>
      </div>

      <div id="period-fields" hidden>
        <label class="dlg-field">
          <span>开始日期</span>
          <input type="date" id="edit-start-date" required />
        </label>
        <label class="dlg-field">
          <span>结束日期</span>
          <input type="date" id="edit-end-date" required />
        </label>
      </div>

      <label class="dlg-field">
        <span>时间</span>
        <input type="text" name="time" id="edit-time" placeholder="10:00 或 全天" required maxlength="32" />
      </label>
      <label class="dlg-field">
        <span>标题</span>
        <input type="text" name="title" id="edit-title-input" required maxlength="200" />
      </label>

      <div class="dlg-field">
        <span>类别</span>
        <div class="cat-picker" id="cat-picker"></div>
        <input type="hidden" name="category" id="edit-category" value="research" />
      </div>

      <label class="dlg-field dlg-color-row">
        <span>颜色</span>
        <span class="color-row-inner">
          <input type="color" id="edit-color" value="#5b7fc7" />
          <button type="button" class="ed-btn ghost" id="reset-color">重置为默认</button>
        </span>
      </label>

      <p class="dlg-error" id="edit-error" hidden></p>
      <div class="dlg-actions">
        <button type="button" class="ed-btn danger" id="edit-delete" hidden>删除</button>
        <span class="dlg-spacer"></span>
        <button type="button" class="ed-btn ghost" id="edit-cancel">取消</button>
        <button type="submit" class="ed-btn primary">保存</button>
      </div>
    </form>
  </dialog>

  <script is:inline define:vars={{ categories }}>
    window.__SCHEDULE_CATEGORIES__ = categories;
  </script>
</BaseLayout>

<style is:global>
  :root {
    --st-bg: #ffffff;
    --st-text: #161616;
    --st-muted: #6b7280;
    --st-line: #e8e8e8;
    --st-pop: #2b6ed3;
    --st-now: #e34432;
    --st-tint: #eef3fc;
    --st-card: #f7f8fa;
    --st-today-bg: #eef3fc;
    --st-today-bd: var(--st-pop);
    --st-shadow: 0 2px 10px rgba(0,0,0,0.06);
  }

  .sched-page { max-width: 920px; margin: 0 auto; }

  .sched-toolbar {
    display: flex; align-items: center; justify-content: space-between;
    gap: 1rem; flex-wrap: wrap; margin-bottom: 1.2rem;
  }
  .sched-title h1 { margin: 0; font-size: 1.6rem; line-height: 1.2; letter-spacing: -0.01em; }
  .sched-actions { display: flex; gap: 0.4rem; align-items: center; }
  .tb-group { display: inline-flex; align-items: center; gap: 0; border: 1px solid var(--st-line); border-radius: 10px; background: var(--st-bg); overflow: hidden; }
  .tb-btn { min-width: 2.2rem; height: 2.2rem; padding: 0 0.5rem; border: none; background: transparent; color: var(--st-text); font-family: inherit; font-size: 0.9rem; cursor: pointer; transition: background 0.12s ease; }
  .tb-btn:hover { background: var(--st-card); }
  .tb-btn:active { transform: translateY(1px); }
  .tb-label { padding: 0 0.6rem; font-size: 0.88rem; font-weight: 500; color: var(--st-text); white-space: nowrap; min-width: 6.5rem; text-align: center; }
  .tb-today { font-weight: 600; color: var(--st-pop); border: 1px solid var(--st-line); border-radius: 10px; margin-left: 0.2rem; }
  .tb-today:hover { background: var(--st-tint); }
  .tb-login { color: var(--st-muted); border: 1px solid transparent; border-radius: 10px; }
  .tb-login:hover { border-color: var(--st-line); background: var(--st-card); }
  .tb-login.is-authed { color: var(--st-pop); border-color: var(--st-pop); background: var(--st-tint); }

  .sched-grid {
    display: grid; grid-template-columns: 1fr 300px; gap: 1.2rem; align-items: flex-start;
  }

  /* ===== Calendar ===== */
  .cal-panel {
    border: 1px solid var(--st-line); border-radius: 12px; background: var(--st-bg);
    overflow: hidden; max-width: 100%; box-shadow: var(--st-shadow);
  }
  .cal-head {
    display: grid; grid-template-columns: repeat(7, 1fr);
    background: var(--st-card); border-bottom: 1px solid var(--st-line);
    text-align: center; font-size: 0.78rem; font-weight: 500; color: var(--st-muted);
    padding: 0.6rem 0; letter-spacing: 0.04em;
  }
  .cal-body { position: relative; display: grid; grid-template-columns: repeat(7, 1fr); }
  .cal-bands-layer {
    position: absolute; inset: 0;
    pointer-events: none; z-index: 2;
  }
  .cal-bands-layer .period-band { pointer-events: auto; }
  .cal-cell {
    position: relative; height: 124px; padding: 0.4rem 0.35rem 0.3rem;
    border-right: 1px solid #f2f2f2; border-bottom: 1px solid #f2f2f2;
    background: var(--st-bg); cursor: pointer; transition: background 0.1s ease;
    display: flex; flex-direction: column; gap: 0.18rem;
    overflow: hidden;
  }
  .cal-cell:nth-child(7n) { border-right: 0; }
  .cal-cell:hover { background: var(--st-card); }
  .cal-cell.outside { opacity: 0.4; }
  .cal-cell.outside:hover { opacity: 0.6; }
  .cal-cell.weekend .day-num { color: var(--st-muted); }
  .cal-cell.today { background: #f8faff; }
  .cal-cell.today .day-num {
    background: var(--st-today-bd); color: #fff; width: 1.6rem; height: 1.6rem;
    box-shadow: 0 1px 4px rgba(43,110,211,0.25);
  }
  .cal-cell.selected { background: #f4f7fd; }
  .cal-cell.selected .day-num { box-shadow: 0 0 0 2px var(--st-pop); color: var(--st-pop); }
  .cal-cell.today.selected .day-num { box-shadow: 0 0 0 2px var(--st-pop); background: var(--st-today-bd); color: #fff; }

  .day-num {
    display: inline-flex; align-items: center; justify-content: center;
    width: 1.55rem; height: 1.55rem; border-radius: 8px;
    font-size: 0.82rem; font-weight: 500; color: var(--st-text);
    transition: all 0.12s ease; margin-bottom: 0.1rem;
  }

  .chip {
    font-size: 0.71rem;
    color: var(--chip-c, var(--st-pop));
    background: var(--chip-t, var(--st-tint));
    border-left: 3px solid var(--chip-cb, var(--st-pop));
    border-radius: 3px;
    padding: 0.03rem 0.3rem;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    line-height: 1.45; font-weight: 500;
  }
  .chip.done-1 { text-decoration: wavy line-through; text-decoration-color: var(--chip-c, currentColor); opacity: 0.55; }
  .chip.done-2 { opacity: 0.30; filter: grayscale(0.6); }

  /* Period chips no longer appear in cells; period entries render as
     cross-cell .period-band overlays (see below). */

  /* Period bands — absolute overlay inside .cal-bands-layer, positioned
     via JS using cell bounding rects. Does NOT participate in grid layout. */
  .period-band {
    position: absolute; cursor: pointer;
    overflow: hidden; white-space: nowrap; text-overflow: ellipsis;
    font-size: 0.71rem; line-height: 1.45; font-weight: 500;
    border-radius: 3px;
    border-left: 3px solid var(--chip-cb, var(--st-pop));
    background: var(--chip-t, var(--st-tint));
    color: var(--chip-c, var(--st-pop));
    min-width: 0;
    padding: 0.03rem 0.3rem;
  }
  .period-band.done-1 { text-decoration: wavy line-through; opacity: 0.55; }
  .period-band.done-2 { opacity: 0.30; filter: grayscale(0.6); }
  .period-band:hover { filter: brightness(0.96); }

  /* ===== Agenda ===== */
  .agenda-panel {
    border: 1px solid var(--st-line); border-radius: 12px; background: var(--st-bg);
    padding: 0 0 0.6rem; position: sticky; top: 80px;
    max-width: 100%; box-shadow: var(--st-shadow);
  }
  .agenda-head {
    display: flex; align-items: center; gap: 0.4rem;
    padding: 0.65rem 0.7rem 0.55rem; border-bottom: 1px solid var(--st-line);
  }
  .agenda-head h2 { margin: 0; font-size: 0.95rem; flex: 1; text-align: center; }
  .agenda-count { color: var(--st-muted); font-size: 0.78rem; white-space: nowrap; }
  .day-btn { border: none; background: transparent; color: var(--st-muted); cursor: pointer; font-size: 1rem; padding: 0.15rem 0.25rem; line-height: 1; border-radius: 6px; transition: all 0.1s ease; }
  .day-btn:hover { background: var(--st-card); color: var(--st-text); }

  .agenda-list { list-style: none; margin: 0; padding: 0; }
  .agenda-item {
    display: grid; grid-template-columns: 4px 56px 1fr auto auto;
    gap: 0.5rem; padding: 0.5rem 0.7rem; border-bottom: 1px solid #f2f2f2; align-items: start;
    cursor: default;
  }
  .agenda-item:last-child { border-bottom: 0; }
  .agenda-bar { width: 4px; border-radius: 2px; align-self: stretch; background: var(--bar, var(--st-pop)); flex-shrink: 0; }
  .agenda-time { font-size: 0.8rem; color: var(--st-pop); font-weight: 600; padding-top: 0.08rem; }
  .agenda-time.all-day { color: var(--st-now); }
  .agenda-body { min-width: 0; display: flex; flex-direction: column; justify-content: center; }
  .agenda-title-text { font-size: 0.9rem; color: var(--st-text); line-height: 1.35; overflow-wrap: anywhere; }
  .agenda-item.done-1 .agenda-title-text { text-decoration: wavy line-through; text-decoration-color: var(--bar, var(--st-pop)); opacity: 0.6; }
  .agenda-item.done-2 .agenda-title-text { text-decoration: line-through; text-decoration-color: var(--bar, var(--st-pop)); opacity: 0.35; filter: grayscale(0.6); }
  .agenda-empty { padding: 1.2rem 0.7rem; text-align: center; color: var(--st-muted); font-size: 0.85rem; }
  .agenda-edit-actions { margin: 0.4rem 0.7rem 0; }

  .done-btn {
    border: 1px solid #e0e0e0; border-radius: 50%; width: 1.2rem; height: 1.2rem;
    background: var(--st-bg); color: #bbb; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.65rem; padding: 0; line-height: 1;
    transition: all 0.15s ease; flex-shrink: 0; margin-top: 0.08rem;
  }
  .done-btn:hover { border-color: var(--st-pop); color: var(--st-pop); }
  .done-btn.done-1 { border-color: #f5a623; background: #fef3e0; color: #f5a623; }
  .done-btn.done-2 { border-color: #16a34a; background: #e6f7ec; color: #16a34a; }

  /* ===== Edit buttons ===== */
  .ed-btn { border: 1px solid var(--st-line); background: var(--st-bg); color: var(--st-text); border-radius: 8px; padding: 0.35rem 0.7rem; font-family: inherit; font-size: 0.85rem; cursor: pointer; transition: all 0.12s ease; }
  .ed-btn:hover { background: var(--st-card); border-color: #d0d0d0; }
  .ed-btn.primary { background: var(--st-pop); color: #fff; border-color: var(--st-pop); }
  .ed-btn.primary:hover { background: #1f5bb5; }
  .ed-btn.ghost { background: transparent; border-color: transparent; color: var(--st-muted); }
  .ed-btn.ghost:hover { color: var(--st-text); background: var(--st-card); border-color: var(--st-line); }
  .ed-btn.danger { color: var(--st-now); border-color: #f5d0cc; }
  .ed-btn.danger:hover { background: #fce8e6; }
  .ed-add { width: 100%; }

  .ed-icon-btn { border: none; background: transparent; color: #bbb; cursor: pointer; font-size: 0.9rem; padding: 0 0.15rem; border-radius: 4px; line-height: 1.4; transition: color 0.1s; }
  .ed-icon-btn:hover { color: var(--st-text); }
  body:not(.is-admin) .ed-icons { display: none; }

  .dlg { border: 1px solid var(--st-line); border-radius: 14px; padding: 0; width: min(400px, 92vw); box-shadow: 0 16px 40px rgba(0,0,0,0.16); color: var(--st-text); }
  .dlg::backdrop { background: rgba(0,0,0,0.3); }
  .dlg-form { padding: 1rem 1.1rem; display: flex; flex-direction: column; gap: 0.6rem; }
  .dlg-form h3 { margin: 0 0 0.1rem; font-size: 1rem; }
  .dlg-field { display: flex; flex-direction: column; gap: 0.2rem; font-size: 0.82rem; color: var(--st-muted); }
  .dlg-field input[type="text"], .dlg-field input[type="password"], .dlg-field input[type="date"] { border: 1px solid var(--st-line); border-radius: 8px; padding: 0.4rem 0.5rem; font-family: inherit; font-size: 0.92rem; color: var(--st-text); }
  .dlg-field input:focus { outline: 2px solid var(--st-pop); outline-offset: -1px; border-color: var(--st-pop); }
  .dlg-error { margin: 0; color: var(--st-now); font-size: 0.82rem; }
  .dlg-actions { display: flex; gap: 0.4rem; align-items: center; justify-content: flex-end; margin-top: 0.1rem; }
  .dlg-spacer { flex: 1; }
  .dlg-color-row { flex-direction: row; align-items: center; gap: 0.5rem; }
  .dlg-color-row > span { min-width: 3.5rem; }
  .color-row-inner { display: flex; align-items: center; gap: 0.4rem; }
  .color-row-inner input[type="color"] { width: 2rem; height: 2rem; padding: 0; border: 1px solid var(--st-line); border-radius: 8px; cursor: pointer; }

  .mode-tabs { display: flex; border: 1px solid var(--st-line); border-radius: 10px; overflow: hidden; }
  .mode-tab { flex: 1; border: none; background: var(--st-bg); color: var(--st-muted); padding: 0.4rem 0; font-family: inherit; font-size: 0.82rem; cursor: pointer; transition: all 0.12s ease; }
  .mode-tab.is-active { background: var(--st-pop); color: #fff; font-weight: 500; }
  .mode-tab:hover:not(.is-active) { background: var(--st-card); }

  .cat-picker { display: flex; flex-wrap: wrap; gap: 0.35rem; }
  .cat-swatch { border: 1px solid var(--st-line); background: var(--st-bg); border-radius: 999px; padding: 0.18rem 0.5rem; font-size: 0.8rem; cursor: pointer; display: inline-flex; align-items: center; gap: 0.25rem; color: var(--st-text); transition: all 0.1s ease; }
  .cat-swatch .dot { width: 0.6rem; height: 0.6rem; border-radius: 50%; background: var(--c, #ccc); display: inline-block; flex-shrink: 0; }
  .cat-swatch.is-active { border-color: var(--c); background: var(--t, var(--st-card)); font-weight: 500; }

  @media (max-width: 760px) {
    .sched-grid { grid-template-columns: 1fr; }
    .agenda-panel { position: static; }
    .cal-cell { height: 110px; padding: 0.25rem 0.25rem 0.15rem; }
  }
</style>

<script>
  // ---------------------------------------------------------------------------
  // Types & data
  // ---------------------------------------------------------------------------
  type ScheduleEntry = {
    id?: string; time: string; title: string; category?: string;
    color?: string; done?: number; isPeriod?: boolean;
  };
  type Schedule = Record<string, any>;

  const CATS: Array<{ key: string; zh: string; h: string; s: string }> =
    (window as any).__SCHEDULE_CATEGORIES__ ?? [];

  const SHADES = [
    { bgL: 95, fgL: 38, bdL: 65 },
    { bgL: 91, fgL: 44, bdL: 59 },
    { bgL: 87, fgL: 50, bdL: 53 },
    { bgL: 83, fgL: 56, bdL: 47 },
  ];

  const DEFAULT_TODAY = new Intl.DateTimeFormat("en-CA", {
    timeZone: "Asia/Shanghai", year: "numeric", month: "2-digit", day: "2-digit",
  }).format(new Date());

  function pad(n: number): string { return String(n).padStart(2, "0"); }
  function dateKey(y: number, m: number, d: number): string { return `${y}-${pad(m+1)}-${pad(d)}`; }
  function escapeHtml(s: string): string { return s.replace(/[&<>"']/g, (c) => "&#" + c.charCodeAt(0) + ";"); }
  function genId(): string { return "e" + Date.now().toString(36) + Math.random().toString(36).slice(2, 8); }
  function parseDate(str: string): { y: number; m: number; d: number } {
    const [y, m, d] = str.split("-").map(Number); return { y, m: m - 1, d };
  }

  function chipColors(cat: string | undefined, shade: number): string {
    const c = CATS.find((x) => x.key === (cat || "other"));
    if (!c) return `--chip-c:#555;--chip-t:#eee;--chip-cb:#555;--bar:#555;`;
    const s = SHADES[shade % SHADES.length];
    const fg = `hsl(${c.h}, ${c.s}%, ${s.fgL}%)`;
    const bg = `hsl(${c.h}, ${c.s}%, ${s.bgL}%)`;
    const bd = `hsl(${c.h}, ${c.s}%, ${s.bdL}%)`;
    return `--chip-c:${fg};--chip-t:${bg};--chip-cb:${bd};--bar:${fg};`;
  }

  function baseHex(cat: string): string {
    const c = CATS.find((x) => x.key === (cat || "other"));
    if (!c) return "#6b7280";
    const vals: Record<string,string> = { research:"#3b7dd8", study:"#7c4dff", life:"#3ba366", outing:"#e8913a", ddl:"#dc2626", other:"#6b7280" };
    return vals[c.key] ?? "#6b7280";
  }

  // ---------------------------------------------------------------------------
  // Done state (localStorage, no login needed)
  // ---------------------------------------------------------------------------
  const DONE_KEY = "sched_done_v1";

  function loadDone(): Record<string, number> {
    try { return JSON.parse(localStorage.getItem(DONE_KEY) || "{}"); } catch { return {}; }
  }
  function saveDone(map: Record<string, number>) { localStorage.setItem(DONE_KEY, JSON.stringify(map)); }

  /** The done key for an entry on a given date. For non-period entries date is ignored. */
  function doneKey(entry: ScheduleEntry, date: string): string {
    return entry.isPeriod ? `${entry.id}_${date}` : (entry.id || entry.title);
  }
  /** Get done level for an entry on a date. */
  function getDone(entry: ScheduleEntry, date: string): number {
    return loadDone()[doneKey(entry, date)] || 0;
  }
  /** Toggle done: 0→1→2→0. Returns new level. */
  function toggleDone(entry: ScheduleEntry, date: string): number {
    const m = loadDone();
    const k = doneKey(entry, date);
    const cur = m[k] || 0;
    const next = cur >= 2 ? 0 : cur + 1;
    if (next === 0) delete m[k]; else m[k] = next;
    saveDone(m);
    return next;
  }

  // ---------------------------------------------------------------------------
  // Global entry rank (for consistent chip Y-order across cells)
  // ---------------------------------------------------------------------------
  let _globalRank: Map<string, number> = new Map();
  let _rankDirty = true;

  function computeGlobalRanks() {
    if (!_rankDirty) return;
    _globalRank = new Map();
    let r = 0;
    const plist = schedule.__periods__ || [];
    for (const p of plist) {
      if (!_globalRank.has(p.id)) _globalRank.set(p.id, r++);
    }
    // direct entries across all visible dates
    for (let d = 1; d <= 31; d++) {
      const cd = dateKey(viewYear, viewMonth, d);
      const evts = schedule[cd] || [];
      for (const e of evts) {
        if (!_globalRank.has(e.id)) _globalRank.set(e.id, r++);
      }
    }
    _rankDirty = false;
  }

  function entryRank(e: ScheduleEntry): number { return _globalRank.get(e.id || "") ?? 999; }

  // ---------------------------------------------------------------------------
  // State
  // ---------------------------------------------------------------------------
  const root = document.querySelector<HTMLElement>(".sched-page")!;
  if (!root) throw new Error("no .sched-page");

  let schedule = JSON.parse(root.dataset.schedule || "{}") as Schedule;
  let todayStr = DEFAULT_TODAY;
  let viewYear = new Date().getFullYear();
  let viewMonth = new Date().getMonth();
  let selectedDate = DEFAULT_TODAY;
  let isAuthed = false;

  const monthLabel = document.getElementById("month-label")!;
  const calBody = document.getElementById("cal-body")!;
  const agendaList = document.getElementById("agenda-list")!;
  const agendaCount = document.getElementById("agenda-count")!;
  const agendaTitle = document.getElementById("agenda-title")!;
  const editActions = document.getElementById("agenda-edit-actions")!;
  const loginBtn = document.getElementById("login-btn")!;
  const apiBase = root.dataset.api || "/api";
  const monthNames = ["一月","二月","三月","四月","五月","六月","七月","八月","九月","十月","十一月","十二月"];
  const dayNames = ["周日","周一","周二","周三","周四","周五","周六"];

  function eventsFor(d: string): ScheduleEntry[] {
    const direct = schedule[d] || [];
    const periods = schedule.__periods__ || [];
    const fromPeriods = periods
      .filter((p: any) => p.start <= d && d <= p.end)
      .map((p: any) => ({ id: p.id, time: p.time || "全天", title: p.title, category: p.category, color: p.color, isPeriod: true, done: p.done }));
    return [...fromPeriods, ...direct];
  }
  /** Non-period entries only (for calendar chip rendering). */
  function nonPeriodEventsFor(d: string): ScheduleEntry[] {
    return (schedule[d] || []).filter((e: ScheduleEntry) => {
      const p = (schedule.__periods__ || []).find((x: any) => x.id === e.id);
      return !p;
    });
  }
  function periods(): any[] { return schedule.__periods__ || []; }

  // ---------------------------------------------------------------------------
  // Period bands (cross-cell overlays)
  // ---------------------------------------------------------------------------
  /** Compare two "YYYY-MM-DD" strings lexicographically (works for ISO dates). */
  function dateCmp(a: string, b: string): number { return a < b ? -1 : a > b ? 1 : 0; }

  /** Render period bands as absolute overlays over the calendar grid.
      Bands do NOT participate in grid layout — they're positioned in a
      separate absolute layer using measured cell rects. */
  function renderPeriodBands(cellDates: string[]) {
    let layer = calBody.querySelector<HTMLElement>(".cal-bands-layer");
    if (!layer) {
      layer = document.createElement("div");
      layer.className = "cal-bands-layer";
      calBody.appendChild(layer);
    } else {
      layer.innerHTML = "";
    }

    const plist = periods();
    if (plist.length === 0 || cellDates.length === 0) return;

    const cells = Array.from(calBody.querySelectorAll<HTMLElement>(".cal-cell"));
    if (cells.length !== cellDates.length) return;
    const cellRects = cells.map((c) => c.getBoundingClientRect());
    const bodyRect = calBody.getBoundingClientRect();

    const viewStart = cellDates[0];
    const viewEnd = cellDates[cellDates.length - 1];

    // Measure real cell positions (absolute coords relative to calBody).
    const rem = parseFloat(getComputedStyle(document.documentElement).fontSize) || 16;
    const cellHPad = 0.35 * rem;

    for (let slotIdx = 0; slotIdx < plist.length; slotIdx++) {
      const p = plist[slotIdx];
      const segStart = dateCmp(p.start, viewStart) < 0 ? viewStart : p.start;
      const segEnd = dateCmp(p.end, viewEnd) > 0 ? viewEnd : p.end;
      if (dateCmp(segStart, segEnd) > 0) continue;

      // Build segments by walking days and splitting on row change.
      const segs: { rowIdx: number; startDate: string; endDate: string }[] = [];
      let cur = segStart;
      let seg: { rowIdx: number; startDate: string; endDate: string } | null = null;
      while (dateCmp(cur, segEnd) <= 0) {
        const idx = cellDates.indexOf(cur);
        if (idx < 0) break;
        const r = Math.floor(idx / 7);
        if (seg && r === seg.rowIdx) seg.endDate = cur;
        else { seg = { rowIdx: r, startDate: cur, endDate: cur }; segs.push(seg); }
        const { y, m, d } = parseDate(cur);
        const c = new Date(y, m, d); c.setDate(c.getDate() + 1);
        cur = dateKey(c.getFullYear(), c.getMonth(), c.getDate());
      }

      const customColor = p.color && /^#[0-9a-f]{6}$/.test(p.color);
      const style = customColor
        ? `--chip-c:${p.color};--chip-t:${p.color}22;--chip-cb:${p.color};`
        : chipColors(p.category || "other", 0);

      for (const seg of segs) {
        const startIdx = cellDates.indexOf(seg.startDate);
        const endIdx = cellDates.indexOf(seg.endDate);
        if (startIdx < 0 || endIdx < 0) continue;
        const startCell = cellRects[startIdx];
        const endCell = cellRects[endIdx];
        const left = startCell.left + cellHPad;
        const right = endCell.right - cellHPad;
        const width = Math.max(right - left, 16);
        // Count only the bands that actually cover this segment's start date and
        // come before this period in plist — that gives the local slot this band
        // occupies in this row, matching the chip-spacer reservation in
        // renderCalendar (see bandSlotCount).
        let localSlot = 0;
        for (const other of plist) {
          if (other === p) break;
          if (other.start <= seg.startDate && seg.startDate <= other.end) localSlot++;
          if (localSlot >= 4) break;
        }
        const topOffset = 36 + Math.min(localSlot, 3) * 22;
        const top = startCell.top + topOffset;
        const segStartDate = seg.startDate;

        const rowEl = document.createElement("div");
        rowEl.className = "period-band";
        rowEl.dataset.id = p.id || "";
        rowEl.dataset.date = segStartDate;
        rowEl.title = `${p.title} (${p.start} → ${p.end})`;
        rowEl.setAttribute("style",
          `left:${left - bodyRect.left}px;top:${top - bodyRect.top}px;width:${width}px;` +
          style);
        rowEl.textContent = p.title;

        const doneLevel = getDone(p as ScheduleEntry, segStartDate);
        if (doneLevel === 1) rowEl.classList.add("done-1");
        if (doneLevel === 2) rowEl.classList.add("done-2");

        layer!.appendChild(rowEl);
      }
    }
  }



  // ---------------------------------------------------------------------------
  // Calendar rendering
  // ---------------------------------------------------------------------------
  function renderCalendar() {
    monthLabel.textContent = `${viewYear} 年 ${monthNames[viewMonth]}`;
    _rankDirty = true;
    computeGlobalRanks();

    const firstDay = new Date(viewYear, viewMonth, 1);
    const firstWeekday = (firstDay.getDay() + 6) % 7;
    const daysInMonth = new Date(viewYear, viewMonth + 1, 0).getDate();
    const prevDays = new Date(viewYear, viewMonth, 0).getDate();
    const totalLeading = firstWeekday;
    const totalCells = Math.ceil((totalLeading + daysInMonth) / 7) * 7;

    let html = "";
    const cellDates: string[] = new Array(totalCells);
    for (let i = 0; i < totalCells; i++) {
      const dayNum = i - totalLeading + 1;
      let cellClass = "cal-cell";
      let cellDate = "";
      let dayLabel = "";

      if (i < totalLeading) {
        const d = prevDays - totalLeading + i + 1;
        const m = viewMonth === 0 ? 11 : viewMonth - 1;
        const y = viewMonth === 0 ? viewYear - 1 : viewYear;
        cellDate = dateKey(y, m, d);
        cellClass += " outside"; dayLabel = String(d);
      } else if (i < totalLeading + daysInMonth) {
        cellDate = dateKey(viewYear, viewMonth, dayNum);
        dayLabel = String(dayNum);
        const dow = new Date(viewYear, viewMonth, dayNum).getDay();
        if (dow === 0 || dow === 6) cellClass += " weekend";
        if (cellDate === todayStr) cellClass += " today";
        if (cellDate === selectedDate) cellClass += " selected";
        if (eventsFor(cellDate).length > 0) cellClass += " has-events";
      } else {
        const d = i - totalLeading - daysInMonth + 1;
        const m = viewMonth === 11 ? 0 : viewMonth + 1;
        const y = viewMonth === 11 ? viewYear + 1 : viewYear;
        cellDate = dateKey(y, m, d);
        cellClass += " outside"; dayLabel = String(d);
      }
      cellDates[i] = cellDate;

      // Chips: skip period entries — they render as cross-cell .period-band overlays.
      const evts = nonPeriodEventsFor(cellDate);
      const sorted = [...evts].sort((a, b) => entryRank(a) - entryRank(b));

      // Reserve slot spacers for visible period bands on this date so that
      // chips naturally sit below the bands. Each period band occupies one
      // row (~22px). The number of bands covering this date = the slot count
      // to reserve.
      const plist = periods();
      let bandSlotCount = 0;
      for (const p of plist) {
        if (p.start <= cellDate && cellDate <= p.end) {
          bandSlotCount++;
          if (bandSlotCount >= 4) break;
        }
      }
      const spacersHtml = bandSlotCount > 0
        ? `<span class="chip-spacer" style="height:${bandSlotCount * 22}px;flex:0 0 auto;"></span>`
        : "";

      // Max total chip elements per cell (including "+N").
      const MAX_CHIPS = 4;
      const chipsHtml: string[] = [];
      // How many task chips to render: at most MAX_CHIPS-1 if there's overflow
      const renderCount = sorted.length > MAX_CHIPS ? MAX_CHIPS - 1 : sorted.length;
      for (let idx = 0; idx < renderCount; idx++) {
        const e = sorted[idx];
        const customColor = e.color && /^#[0-9a-f]{6}$/.test(e.color);
        const shade = customColor ? 0 : idx;
        const allDay = e.time === "全天" || /^\s*全天/.test(e.time);
        const style = customColor
          ? `--chip-c:${e.color};--chip-t:${e.color}22;--chip-cb:${e.color};`
          : chipColors(e.category || "other", shade);
        const doneLevel = getDone(e, cellDate);
        const dCls = doneLevel === 1 ? " done-1" : doneLevel === 2 ? " done-2" : "";
        const cls = "chip" + (allDay && e.category === "other" ? " all-day" : "") + dCls;
        chipsHtml.push(`<span class="${cls}" style="${style}">${escapeHtml(e.title)}</span>`);
      }
      const remaining = sorted.length - chipsHtml.length;
      const more = remaining > 0
        ? `<span class="chip" style="${chipColors("other", 0)}">+${remaining}</span>`
        : "";

      html += `<div class="${cellClass}" data-date="${cellDate}">
        <span class="day-num">${dayLabel}</span>
        ${spacersHtml}${chipsHtml.join("")}${more}
      </div>`;
    }

    calBody.innerHTML = html;

    // --- Render period bands as cross-cell overlays ---
    renderPeriodBands(cellDates);

    calBody.querySelectorAll<HTMLElement>(".cal-cell").forEach((cell) => {
      cell.addEventListener("click", () => {
        selectedDate = cell.dataset.date || selectedDate;
        if (cell.classList.contains("outside")) {
          const { y, m } = parseDate(selectedDate);
          viewYear = y; viewMonth = m;
        }
        renderCalendar();
        renderAgenda();
      });
    });

    // Period band click: select its start date and open editor if authed
    calBody.querySelectorAll<HTMLElement>(".period-band").forEach((band) => {
      band.addEventListener("click", (ev) => {
        ev.stopPropagation();
        const id = band.dataset.id;
        const date = band.dataset.date;
        if (!id) return;
        const p = (schedule.__periods__ || []).find((x: any) => x.id === id);
        if (!p) return;
        // Jump to the period's start if it's outside current month view
        const cellDateInCurView = cellDates.indexOf(date || "") >= 0;
        if (cellDateInCurView) selectedDate = date!;
        else selectedDate = p.start;
        const { y, m } = parseDate(selectedDate);
        if (y !== viewYear || m !== viewMonth) { viewYear = y; viewMonth = m; }
        renderCalendar();
        renderAgenda();
        if (isAuthed) openEditDialog(selectedDate, id);
      });
    });
  }

  // ---------------------------------------------------------------------------
  // Agenda rendering
  // ---------------------------------------------------------------------------
  function renderAgenda() {
    const events = eventsFor(selectedDate);
    const { y, m, d } = parseDate(selectedDate);
    const dateObj = new Date(y, m, d);
    const isToday = selectedDate === todayStr;
    const dow = dayNames[dateObj.getDay()];

    agendaTitle.textContent = isToday ? "今日" : `${m + 1}月${d}日`;
    agendaCount.textContent = events.length ? `${events.length}项` : "";

    if (events.length === 0) {
      agendaList.innerHTML = `<li class="agenda-empty">当天暂无日程安排</li>`;
    } else {
      const sorted = [...events].sort((a, b) => {
        const aa = a.time === "全天" ? "" : a.time;
        const bb = b.time === "全天" ? "" : b.time;
        if (aa !== bb) return aa.localeCompare(bb);
        return entryRank(a) - entryRank(b);
      });

      const catGroup = new Map<string, ScheduleEntry[]>();
      for (const e of sorted) {
        const k = e.category || "other";
        if (!catGroup.has(k)) catGroup.set(k, []);
        catGroup.get(k)!.push(e);
      }
      const shadeIdx = new Map<string, number>();
      for (const [, items] of catGroup) items.forEach((e, i) => shadeIdx.set(e.id || "", i));

      agendaList.innerHTML = sorted.map((e) => {
        const allDay = e.time === "全天" || /^\s*全天/.test(e.time);
        const cat = e.category || "other";
        const sIdx = shadeIdx.get(e.id || "") ?? 0;
        const customColor = e.color && /^#[0-9a-f]{6}$/.test(e.color);
        const style = customColor ? `--bar:${e.color};` : chipColors(cat, sIdx);
        const doneLevel = getDone(e, selectedDate);
        const dCls = doneLevel === 1 ? " done-1" : doneLevel === 2 ? " done-2" : "";
        const doneLabels = ["○", "◡", "✓"];
        return `<li class="agenda-item${dCls}" data-id="${e.id || ""}" data-date="${selectedDate}">
          <div class="agenda-bar" style="${style}"></div>
          <div class="agenda-time${allDay ? " all-day" : ""}">${escapeHtml(e.time)}</div>
          <div class="agenda-body">
            <div class="agenda-title-text">${escapeHtml(e.title)}</div>
          </div>
          <button class="done-btn done-${doneLevel}" data-act="done" title="完成状态">${doneLabels[doneLevel]}</button>
          <div class="ed-icons">
            <button class="ed-icon-btn" data-act="edit" title="编辑">&#9998;</button>
            <button class="ed-icon-btn" data-act="del" title="删除">&#10005;</button>
          </div>
        </li>`;
      }).join("");
      wireAgendaActions();
    }
  }

  function wireAgendaActions() {
    agendaList.querySelectorAll<HTMLElement>(".agenda-item").forEach((li) => {
      // done button — always active, no login needed
      const doneBtn = li.querySelector<HTMLButtonElement>(".done-btn");
      if (doneBtn) {
        doneBtn.addEventListener("click", (ev) => {
          ev.stopPropagation();
          const entryDate = li.dataset.date || selectedDate;
          const id = li.dataset.id;
          if (!id) return;
          // Find the entry
          const evts = eventsFor(entryDate);
          const entry = evts.find(e => e.id === id);
          if (!entry) return;
          toggleDone(entry, entryDate);
          renderAgenda();
          renderCalendar(); // calendar chips update too
        });
      }

      // edit / delete — admin only
      if (!isAuthed) return;
      li.querySelectorAll<HTMLButtonElement>(".ed-icon-btn").forEach((b) => {
        b.addEventListener("click", (ev) => {
          ev.stopPropagation();
          const id = li.dataset.id;
          if (b.dataset.act === "del" && id) {
            if (confirm("删除该条日程？")) deleteEntry(selectedDate, id);
          } else if (b.dataset.act === "edit" && id) {
            openEditDialog(selectedDate, id);
          }
        });
      });
      li.addEventListener("click", () => {
        const id = li.dataset.id;
        if (id && isAuthed) openEditDialog(selectedDate, id);
      });
    });
  }

  // ---------------------------------------------------------------------------
  // Editing (OPTIMISTIC: update local state + render first, save in background,
  // roll back on failure so the UI stays responsive even on a slow link).
  // ---------------------------------------------------------------------------
  // In-flight save promises keyed by an incrementing counter, so we can show
  // a subtle "saving…" indicator without blocking interaction.
  let saveInFlight = 0;
  const updateSaving = () => {
    const el = document.getElementById("save-indicator");
    if (el) el.hidden = saveInFlight === 0;
  };

  async function persistSave(scheduleSnapshot: Schedule): Promise<void> {
    saveInFlight++; updateSaving();
    try {
      const res = await fetch(`${apiBase}/schedule/saveAll`, {
        method: "POST", credentials: "omit",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ schedule: scheduleSnapshot }),
      });
      if (!res.ok) {
        const txt = await res.text().catch(() => "");
        throw new Error(txt || `保存失败 (${res.status})`);
      }
    } finally {
      saveInFlight--; updateSaving();
    }
  }

  // Always send the entire (already-mutated) schedule object. saveAll only
  // overwrites known keys (__periods__ + yyyy-mm-dd), preserving the rest.
  function commitAndPersist(prevSnapshot: Schedule, errMsg = "保存失败，已回滚"): void {
    renderCalendar(); renderAgenda();
    // Fire-and-forget; rollback on rejection.
    persistSave(structuredClone(schedule)).catch((err) => {
      console.error("Save failed, rolling back", err);
      schedule = prevSnapshot;
      renderCalendar(); renderAgenda();
      alert(err?.message || errMsg);
    });
  }

  function snapshot(): Schedule {
    return structuredClone(schedule);
  }

  async function saveDate(date: string, entries: ScheduleEntry[]) {
    const prev = snapshot();
    const arr = Array.isArray(entries) ? entries : [];
    if (arr.length === 0) delete schedule[date]; else schedule[date] = arr;
    commitAndPersist(prev);
  }

  async function addOrUpdateEntry(date: string, entry: ScheduleEntry) {
    const prev = snapshot();
    const arr = [...(schedule[date] || [])];
    const idx = arr.findIndex((e) => e.id === entry.id);
    if (idx >= 0) arr[idx] = entry;
    else { entry.id = entry.id || genId(); arr.push(entry); }
    schedule[date] = arr;
    commitAndPersist(prev);
  }

  async function deleteEntry(date: string, id: string) {
    const prev = snapshot();
    // Try period entries first.
    const plist = schedule.__periods__ || [];
    if (plist.find((p: any) => p.id === id)) {
      schedule.__periods__ = plist.filter((p: any) => p.id !== id);
      commitAndPersist(prev);
      return;
    }
    // Otherwise it's a single-day entry.
    schedule[date] = (schedule[date] || []).filter((e) => e.id !== id);
    if (schedule[date].length === 0) delete schedule[date];
    commitAndPersist(prev);
  }

  // ---------------------------------------------------------------------------
  // Login (pure client-side Q&A — no server, no network call)
  // ---------------------------------------------------------------------------
  // Auth lives entirely in the browser: sessionStorage records the unlock
  // timestamp; ttlSec bounds how long the authed state survives. There is
  // intentionally NO server round-trip — the deployed site is a static
  // GitHub Pages build and has no backend, so any fetch to /api/login would
  // always 405.
  const CHALLENGE_QUESTION = "章鱼哥的紧箍咒是？";
  const ACCEPTED_ANSWERS = ["海绵宝宝", "bob"];
  const AUTH_KEY = "sched_auth_v1";
  const AUTH_TTL_SEC = 14 * 24 * 60 * 60; // 14 days, matches the legacy cookie TTL

  function isAnswerValid(s: string): boolean {
    const norm = String(s).toLowerCase().trim();
    return ACCEPTED_ANSWERS.some(a => a.toLowerCase() === norm);
  }

  function readStoredAuth(): boolean {
    try {
      const raw = sessionStorage.getItem(AUTH_KEY);
      if (!raw) return false;
      const ts = Number(raw);
      if (!Number.isFinite(ts)) return false;
      if (Date.now() / 1000 - ts > AUTH_TTL_SEC) {
        sessionStorage.removeItem(AUTH_KEY);
        return false;
      }
      return true;
    } catch { return false; }
  }

  function writeStoredAuth() {
    try { sessionStorage.setItem(AUTH_KEY, String(Math.floor(Date.now() / 1000))); } catch { /* ignore */ }
  }
  function clearStoredAuth() {
    try { sessionStorage.removeItem(AUTH_KEY); } catch { /* ignore */ }
  }

  const loginDlg = document.getElementById("login-dlg") as HTMLDialogElement;
  const loginForm = document.getElementById("login-form") as HTMLFormElement;
  const loginError = document.getElementById("login-error")!;
  const loginAnswer = document.getElementById("login-answer") as HTMLInputElement;
  const loginCancel = document.getElementById("login-cancel")!;
  document.getElementById("login-question")!.textContent = CHALLENGE_QUESTION;

  loginBtn.addEventListener("click", () => {
    if (isAuthed) { clearStoredAuth(); setAuthed(false); }
    else { loginError.hidden = true; loginForm.reset(); loginDlg.showModal(); setTimeout(() => loginAnswer.focus(), 50); }
  });
  loginCancel.addEventListener("click", () => loginDlg.close());
  loginForm.addEventListener("submit", (e) => {
    e.preventDefault();
    const answer = String(new FormData(loginForm).get("answer") || "");
    if (!isAnswerValid(answer)) {
      loginError.textContent = "答错了，再试一次";
      loginError.hidden = false;
      loginAnswer.focus();
      loginAnswer.select();
      return;
    }
    writeStoredAuth();
    loginDlg.close(); loginForm.reset();
    loginError.hidden = true;
    setAuthed(true);
  });

  function setAuthed(v: boolean) {
    isAuthed = v;
    document.body.classList.toggle("is-admin", v);
    loginBtn.classList.toggle("is-authed", v);
    loginBtn.title = v ? "已登录（点击退出）" : "回答问题以管理";
    editActions.hidden = !v;
    renderAgenda();
  }

  // ---------------------------------------------------------------------------
  // Edit dialog
  // ---------------------------------------------------------------------------
  const editDlg = document.getElementById("edit-dlg") as HTMLDialogElement;
  const editForm = document.getElementById("edit-form") as HTMLFormElement;
  const editTitleH = document.getElementById("edit-title")!;
  const editId = document.getElementById("edit-id") as HTMLInputElement;
  const editDate = document.getElementById("edit-date") as HTMLInputElement;
  const editStartDate = document.getElementById("edit-start-date") as HTMLInputElement;
  const editEndDate = document.getElementById("edit-end-date") as HTMLInputElement;
  const editTime = document.getElementById("edit-time") as HTMLInputElement;
  const editTitleInput = document.getElementById("edit-title-input") as HTMLInputElement;
  const editCategory = document.getElementById("edit-category") as HTMLInputElement;
  const editColor = document.getElementById("edit-color") as HTMLInputElement;
  const editError = document.getElementById("edit-error")!;
  const editDelete = document.getElementById("edit-delete")!;
  const editCancel = document.getElementById("edit-cancel")!;
  const resetColor = document.getElementById("reset-color")!;
  const modeTabs = document.querySelectorAll<HTMLButtonElement>(".mode-tab");
  const singleFields = document.getElementById("single-fields")!;
  const periodFields = document.getElementById("period-fields")!;
  let currentMode: "single" | "period" = "single";

  modeTabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      modeTabs.forEach((t) => t.classList.remove("is-active"));
      tab.classList.add("is-active");
      currentMode = tab.dataset.mode as "single" | "period";
      singleFields.hidden = currentMode !== "single";
      periodFields.hidden = currentMode !== "period";
      // When switching to period mode, default time to 全天;
      // when switching back to single, restore a reasonable default.
      if (currentMode === "period" && !editId.value) editTime.value = "全天";
      if (currentMode === "single" && !editId.value) editTime.value = "10:00";
    });
  });

  const catPicker = document.getElementById("cat-picker")!;
  function renderCatPicker(activeCat: string) {
    catPicker.innerHTML = CATS.map((p) => {
      const hex = baseHex(p.key);
      return `<button type="button" class="cat-swatch${p.key === activeCat ? " is-active" : ""}" data-cat="${p.key}" style="--c:${hex};--t:${hex}22;"><span class="dot"></span>${p.zh}</button>`;
    }).join("");
    catPicker.querySelectorAll<HTMLButtonElement>(".cat-swatch").forEach((b) => {
      b.addEventListener("click", () => {
        catPicker.querySelectorAll(".cat-swatch").forEach((x) => x.classList.remove("is-active"));
        b.classList.add("is-active");
        editCategory.value = b.dataset.cat || "other";
        editColor.value = baseHex(editCategory.value);
      });
    });
  }

  resetColor.addEventListener("click", () => { editColor.value = baseHex(editCategory.value); });

  function openEditDialog(date: string, id?: string) {
    editError.hidden = true;
    currentMode = "single";
    modeTabs.forEach((t) => t.classList.toggle("is-active", t.dataset.mode === "single"));
    singleFields.hidden = false; periodFields.hidden = true;
    editDate.value = date;

    if (id) {
      const periodList = schedule.__periods__ || [];
      const pEntry = periodList.find((p: any) => p.id === id);
      if (pEntry) {
        currentMode = "period";
        modeTabs.forEach((t) => t.classList.toggle("is-active", t.dataset.mode === "period"));
        singleFields.hidden = true; periodFields.hidden = false;
        editId.value = pEntry.id || "";
        editStartDate.value = pEntry.start || date;
        editEndDate.value = pEntry.end || date;
        editTime.value = pEntry.time || "全天";
        editTitleInput.value = pEntry.title;
        editCategory.value = pEntry.category || "other";
        editColor.value = pEntry.color || baseHex(pEntry.category || "other");
        editTitleH.textContent = "编辑周期规划"; editDelete.hidden = false;
        renderCatPicker(editCategory.value); editDlg.showModal(); return;
      }
      const e = (schedule[date] || []).find((x) => x.id === id);
      if (!e) return;
      editId.value = e.id || ""; editTime.value = e.time; editTitleInput.value = e.title;
      editDate.value = date; editCategory.value = e.category || "other";
      editColor.value = e.color || baseHex(e.category || "other");
      editTitleH.textContent = "编辑日程"; editDelete.hidden = false;
    } else {
      editId.value = ""; editTitleInput.value = "";
      editCategory.value = "other"; editColor.value = baseHex("other");
      editDate.value = date; editStartDate.value = date; editEndDate.value = date;
      // New entry: if currently in period mode default to 全天, else 10:00.
      editTime.value = currentMode === "period" ? "全天" : "10:00";
      editTitleH.textContent = "新增日程"; editDelete.hidden = true;
    }
    renderCatPicker(editCategory.value); editDlg.showModal(); setTimeout(() => editTime.focus(), 50);
  }

  document.getElementById("add-btn")?.addEventListener("click", () => openEditDialog(selectedDate));
  editCancel.addEventListener("click", () => editDlg.close());

  editDelete.addEventListener("click", () => {
    const id = editId.value;
    if (!id || !confirm("删除该条日程？")) return;
    editDlg.close();
    const date = editDate.value;
    const prev = snapshot();
    // Check period entries first.
    const plist = schedule.__periods__ || [];
    if (plist.find((p: any) => p.id === id)) {
      schedule.__periods__ = plist.filter((p: any) => p.id !== id);
      commitAndPersist(prev);
      return;
    }
    schedule[date] = (schedule[date] || []).filter((e: any) => e.id !== id);
    if (schedule[date].length === 0) delete schedule[date];
    commitAndPersist(prev);
  });

  editForm.addEventListener("submit", (e) => {
    e.preventDefault();
    if (!editTitleInput.value.trim()) { editError.textContent = "请填写标题"; editError.hidden = false; return; }
    const color = editColor.value;
    const colorVal = color && color !== baseHex(editCategory.value) ? color : undefined;
    const baseEntry: ScheduleEntry = {
      time: editTime.value.trim() || "全天", title: editTitleInput.value.trim(),
      category: editCategory.value, color: colorVal,
    };
    const prev = snapshot();
    try {
      if (currentMode === "single") {
        const date = editDate.value;
        if (!/^\d{4}-\d{2}-\d{2}$/.test(date)) { editError.textContent = "日期格式错误"; editError.hidden = false; return; }
        const entry = { ...baseEntry, id: editId.value || genId() };
        const arr = [...(schedule[date] || [])];
        const idx = arr.findIndex((x: any) => x.id === entry.id);
        if (idx >= 0) arr[idx] = entry; else arr.push(entry);
        schedule[date] = arr;
        if (date !== selectedDate) {
          selectedDate = date; const { y, m } = parseDate(date);
          if (y !== viewYear || m !== viewMonth) { viewYear = y; viewMonth = m; }
        }
      } else {
        const start = editStartDate.value; const end = editEndDate.value;
        if (!/^\d{4}-\d{2}-\d{2}$/.test(start) || !/^\d{4}-\d{2}-\d{2}$/.test(end)) { editError.textContent = "日期格式错误"; editError.hidden = false; return; }
        if (end < start) { editError.textContent = "结束日期不能早于开始日期"; editError.hidden = false; return; }
        const periodEntry = { id: editId.value || genId(), start, end, time: baseEntry.time, title: baseEntry.title, category: baseEntry.category, color: baseEntry.color, done: 0 };
        const plist = [...(schedule.__periods__ || [])];
        const pIdx = plist.findIndex((p: any) => p.id === periodEntry.id);
        if (pIdx >= 0) plist[pIdx] = periodEntry; else plist.push(periodEntry);
        schedule.__periods__ = plist;
        selectedDate = start; const { y, m } = parseDate(start);
        if (y !== viewYear || m !== viewMonth) { viewYear = y; viewMonth = m; }
      }
      editDlg.close();
      commitAndPersist(prev);
    } catch (err: any) { editError.textContent = err?.message || "保存失败"; editError.hidden = false; }
  });

  // ---------------------------------------------------------------------------
  // Navigation
  // ---------------------------------------------------------------------------
  document.getElementById("prev-month")?.addEventListener("click", () => { if (viewMonth === 0) { viewMonth = 11; viewYear--; } else viewMonth--; renderCalendar(); renderAgenda(); });
  document.getElementById("next-month")?.addEventListener("click", () => { if (viewMonth === 11) { viewMonth = 0; viewYear++; } else viewMonth++; renderCalendar(); renderAgenda(); });
  document.getElementById("today-btn")?.addEventListener("click", () => { const n=new Date(); viewYear=n.getFullYear(); viewMonth=n.getMonth(); selectedDate=todayStr; renderCalendar(); renderAgenda(); });
  document.getElementById("prev-day")?.addEventListener("click", () => { const {y,m,d}=parseDate(selectedDate); const c=new Date(y,m,d); c.setDate(c.getDate()-1); selectedDate=dateKey(c.getFullYear(),c.getMonth(),c.getDate()); if (c.getFullYear()!==viewYear||c.getMonth()!==viewMonth) { viewYear=c.getFullYear(); viewMonth=c.getMonth(); } renderCalendar(); renderAgenda(); });
  document.getElementById("next-day")?.addEventListener("click", () => { const {y,m,d}=parseDate(selectedDate); const c=new Date(y,m,d); c.setDate(c.getDate()+1); selectedDate=dateKey(c.getFullYear(),c.getMonth(),c.getDate()); if (c.getFullYear()!==viewYear||c.getMonth()!==viewMonth) { viewYear=c.getFullYear(); viewMonth=c.getMonth(); } renderCalendar(); renderAgenda(); });

  document.addEventListener("keydown", (e) => {
    if (e.target instanceof HTMLElement && /INPUT|TEXTAREA|SELECT/.test(e.target.tagName)) return;
    if (document.querySelector("dialog[open]")) return;
    const {y,m,d}=parseDate(selectedDate||todayStr); const c=new Date(y,m,d);
    if (e.key==="ArrowLeft") c.setDate(c.getDate()-1); else if (e.key==="ArrowRight") c.setDate(c.getDate()+1);
    else if (e.key==="ArrowUp") c.setDate(c.getDate()-7); else if (e.key==="ArrowDown") c.setDate(c.getDate()+7);
    else return;
    e.preventDefault(); selectedDate=dateKey(c.getFullYear(),c.getMonth(),c.getDate());
    if (c.getFullYear()!==viewYear||c.getMonth()!==viewMonth) { viewYear=c.getFullYear(); viewMonth=c.getMonth(); }
    renderCalendar(); renderAgenda();
  });

  // ---------------------------------------------------------------------------
  // Auto-refresh
  // ---------------------------------------------------------------------------
  let lastDay = todayStr;
  async function refreshFromServer() {
    try {
      const res = await fetch(`${apiBase}/schedule`, { credentials: "omit" });
      if (res.ok) { const data = await res.json(); if (data && typeof data === "object") { schedule = data as Schedule; renderCalendar(); renderAgenda(); } }
    } catch { /* ignore */ }
  }

  setInterval(() => {
    const now = new Intl.DateTimeFormat("en-CA", { timeZone: "Asia/Shanghai", year: "numeric", month: "2-digit", day: "2-digit" }).format(new Date());
    if (now !== lastDay) { lastDay = now; todayStr = now; if (selectedDate && selectedDate !== todayStr) { const np = new Date(); if (np.getFullYear() !== viewYear || np.getMonth() !== viewMonth) { viewYear = np.getFullYear(); viewMonth = np.getMonth(); } selectedDate = todayStr; renderCalendar(); renderAgenda(); } }
  }, 60000);

  refreshFromServer();
  setInterval(refreshFromServer, 5 * 60000);

  // Re-position period bands on resize — they use absolute pixel coords.
  let _resizeRaf: number | null = null;
  function scheduleBandLayout() {
    if (_resizeRaf !== null) return;
    _resizeRaf = requestAnimationFrame(() => {
      _resizeRaf = null;
      const cells = Array.from(calBody.querySelectorAll<HTMLElement>(".cal-cell"));
      const cellDates = cells.map((c) => c.dataset.date || "");
      if (cellDates.length) renderPeriodBands(cellDates);
    });
  }
  window.addEventListener("resize", scheduleBandLayout);

  // Restore auth from sessionStorage (no server call — GitHub Pages has no backend).
  setAuthed(readStoredAuth());

  renderCalendar();
  renderAgenda();
</script>
</BaseLayout>
